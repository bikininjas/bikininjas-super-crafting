#!/usr/bin/env bash
# Pre-commit hook — compile + test avant chaque commit
# Pour un check complet avec smoke test serveur: FULL_CHECK=1 git commit ...
# Pour juste le smoke test: ./scripts/smoke-test

set -euo pipefail
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Charger JAVA_HOME depuis .env si présent
if [ -f .env ]; then
  set -a && source .env && set +a
fi

echo "🔨 Pre-commit: compileJava + test..."
./gradlew compileJava test

if [ "${FULL_CHECK:-0}" = "1" ]; then
  echo ""
  echo "🔨 Pre-commit: smoke test (démarrage serveur 30s)..."
  echo "eula=true" > run/eula.txt
  timeout 30 ./gradlew runServer --args="nogui" 2>&1 || [ $? -eq 124 ]
  echo "✅ Smoke test OK"
fi

echo "✅ Pre-commit OK"
